<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ApplicationGroupContainerIdentifier</key>
	<string>group.neris.marrony.ColorWheel</string>
	<key>PreferenceSpecifiers</key>
	<array>
		<dict>
			<key>Type</key>
			<string>PSGroupSpecifier</string>
			<key>Title</key>
			<string>Harmony</string>
			<key>FooterText</key>
			<string>Pick the color-wheel model used to compute matching colors. Artist (RYB) matches what fashion and design guides use; Digital (RGB) follows the math used by screens.</string>
		</dict>
		<dict>
			<key>Type</key>
			<string>PSMultiValueSpecifier</string>
			<key>Title</key>
			<string>Color Wheel</string>
			<key>Key</key>
			<string>wheel_model</string>
			<key>DefaultValue</key>
			<string>artist</string>
			<key>Values</key>
			<array>
				<string>artist</string>
				<string>digital</string>
			</array>
			<key>Titles</key>
			<array>
				<string>Artist (RYB)</string>
				<string>Digital (RGB)</string>
			</array>
		</dict>
		<dict>
			<key>Type</key>
			<string>PSGroupSpecifier</string>
			<key>Title</key>
			<string>Quantization</string>
			<key>FooterText</key>
			<string>Optionally snap the detected color to a fixed number of positions on the color wheel, like a printed 12-position art wheel. Off leaves the detected color untouched.</string>
		</dict>
		<dict>
			<key>Type</key>
			<string>PSMultiValueSpecifier</string>
			<key>Title</key>
			<string>Slices</string>
			<key>Key</key>
			<string>slice_count</string>
			<key>DefaultValue</key>
			<integer>0</integer>
			<key>Values</key>
			<array>
				<integer>0</integer>
				<integer>6</integer>
				<integer>12</integer>
				<integer>24</integer>
			</array>
			<key>Titles</key>
			<array>
				<string>Off</string>
				<string>6</string>
				<string>12</string>
				<string>24</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
